DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# Fernet key for encrypting private command text at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate with command above>
ALLOWED_ORIGINS=https://your-app.vercel.app
ADMIN_SECRET=<generate: openssl rand -hex 16>
ADMIN_EMAIL=you@example.com
VIRUSTOTAL_API_KEY=<optional>
# Threat intelligence enrichment — all optional, free tiers available
# URLhaus and ThreatFox require no key (abuse.ch public APIs)
# GreyNoise Community requires no key
ABUSEIPDB_API_KEY=<optional: https://www.abuseipdb.com/register>
OTX_API_KEY=<optional: https://otx.alienvault.com/api>

# Stripe — use test-mode keys (sk_test_...) during development
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get webhook secret from: https://dashboard.stripe.com/test/webhooks (or `stripe listen` CLI)
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe dashboard, paste the price IDs here
STRIPE_PRICE_ID_INDIVIDUAL=price_...
STRIPE_PRICE_ID_TEAMS=price_...
RESEND_API_KEY=<optional: get from resend.com — omit for console fallback in dev>
FROM_EMAIL=cmdcheck <noreply@yourdomain.com>
APP_URL=https://yourdomain.com
